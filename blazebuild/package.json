{
    "name": "@onesoftnet/blazebuild",
    "module": "./build/main/typescript/index.js",
    "private": false,
    "version": "3.0.0",
    "type": "module",
    "dependencies": {
        "chalk": "^5.3.0",
        "glob": "^11.0.3",
        "reflect-metadata": "^0.2.2"
    },
    "devDependencies": {
        "@types/glob": "^9.0.0",
        "@types/node": "^25.9.1",
        "prettier": "^3.6.2",
        "typescript": "^5.8.3"
    },
    "exports": {
        ".": "./build/main/typescript/index.js"
    },
    "typesVersions": {
        "*": {
            "*": [
                "./build/main/typescript/index.d.ts"
            ]
        }
    },
    "files": [
        "src",
        "package.json",
        "tsconfig.json",
        "templates"
    ],
    "bin": {
        "blazebuild": "./build/main/typescript/main.js"
    },
    "scripts": {
        "build": "tsc && node -e 'const fs = require(\"fs\"); const path = require(\"path\"); fs.rmSync(\"build.next\", { recursive: true, force: true }); fs.renameSync(path.resolve(\"build/src\"), \"build.next\"); fs.rmSync(\"build\", { recursive: true }); fs.renameSync(\"build.next\", \"build\");'"
    }
}
